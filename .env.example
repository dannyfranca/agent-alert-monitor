# Copy to .env or export these in the systemd user environment.
# Never commit real tokens or AWS credentials.
# The bundled systemd units set PATH=%h/.local/bin:/usr/local/bin:/usr/bin:/bin
# so live Kanban creation can resolve a standard Hermes CLI install.
# If your Hermes binary lives elsewhere, add a user-service override for PATH.
ALERT_MONITOR_STATE_DIR=./state
SAMPLE_API_AGENT_ALERT_QUEUE_URL=https://sqs.sa-east-1.amazonaws.com/123456789012/sample-api-prod-alerts
SAMPLE_API_AGENT_ALERT_QUEUE_ARN=arn:aws:sqs:sa-east-1:123456789012:sample-api-prod-alerts
SAMPLE_API_AGENT_ALERT_DLQ_URL=https://sqs.sa-east-1.amazonaws.com/123456789012/sample-api-prod-alerts-dlq
SAMPLE_API_AGENT_ALERT_DLQ_ARN=arn:aws:sqs:sa-east-1:123456789012:sample-api-prod-alerts-dlq

# TicketDoVale production values come from the already-managed cloud queue outputs.
# Set these locally from the ticketdovale queue URL/ARN/DLQ outputs before enabling live mode.
TICKETDOVALE_AGENT_ALERT_QUEUE_URL=https://sqs.sa-east-1.amazonaws.com/123456789012/agent-alert-monitor-ticketdovale-prod
TICKETDOVALE_AGENT_ALERT_QUEUE_ARN=arn:aws:sqs:sa-east-1:123456789012:agent-alert-monitor-ticketdovale-prod
TICKETDOVALE_AGENT_ALERT_DLQ_URL=https://sqs.sa-east-1.amazonaws.com/123456789012/agent-alert-monitor-ticketdovale-prod-dlq
TICKETDOVALE_AGENT_ALERT_DLQ_ARN=arn:aws:sqs:sa-east-1:123456789012:agent-alert-monitor-ticketdovale-prod-dlq
TICKETDOVALE_AWS_ACCOUNT_ID=123456789012

ALERT_MONITOR_SQS_SOURCE=sample-api-prod-alerts
ALERT_MONITOR_SAMPLE_API_TELEGRAM_BOT_TOKEN=replace-with-local-sample-api-bot-token
ALERT_MONITOR_SAMPLE_API_TELEGRAM_CHAT_ID=replace-with-sample-api-chat-id
ALERT_MONITOR_TICKETDOVALE_TELEGRAM_BOT_TOKEN=replace-with-local-ticketdovale-status-bot-token
ALERT_MONITOR_TICKETDOVALE_TELEGRAM_CHAT_ID=replace-with-ticketdovale-status-chat-id
ALERT_MONITOR_WORKER_QUEUE_TELEGRAM_BOT_TOKEN=replace-with-local-worker-queue-bot-token
AWS_PROFILE=alert-monitor-readonly
AWS_REGION=sa-east-1
AWS_DEFAULT_REGION=sa-east-1
